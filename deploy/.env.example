IMAGE_TAG=latest
BACKEND_IMAGE=ghcr.io/joeblack2k/retrosavemanager
FRONTEND_IMAGE=ghcr.io/joeblack2k/retrosavemanager-frontend

AUTH_MODE=disabled
VITE_AUTH_REQUIRED=false
HTTP_PORT=80
HTTPS_PORT=443

# Optional if you use a fixed internal hostname
PUBLIC_HOST=retrosavemanager.lan
BASE_URL=
TLS_ENABLED=false

# Persistent data folders (keep both inside one backup root if preferred)
SAVE_ROOT_HOST_PATH=./data/saves
STATE_ROOT_HOST_PATH=./data/state

# Optional macvlan profile settings
MACVLAN_PARENT=eth0
MACVLAN_SUBNET=198.51.100.0/24
MACVLAN_GATEWAY=198.51.100.1
MACVLAN_IP=198.51.100.250
