IMAGE_TAG=latest
IMAGE=ghcr.io/joeblack2k/retrosavemanager

AUTH_MODE=disabled
VITE_AUTH_REQUIRED=false
HTTP_PORT=80
PORT=80

# Optional if you use a fixed internal hostname
PUBLIC_HOST=retrosavemanager.lan
BASE_URL=
TLS_ENABLED=false
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
RAWG_API_KEY=
BOOTSTRAP_DEMO_DATA=false

# Persistent data folders (required, use absolute host paths)
CONFIG_HOST_PATH=/srv/retrosavemanager/config
SAVES_HOST_PATH=/srv/retrosavemanager/saves

# Optional macvlan profile settings
MACVLAN_PARENT=eth0
MACVLAN_SUBNET=198.51.100.0/24
MACVLAN_GATEWAY=198.51.100.1
MACVLAN_IP=198.51.100.250
