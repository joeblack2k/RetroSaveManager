{
  auto_https off
}

:80 {
  encode gzip zstd

  @api {
    path /healthz /v1* /auth* /save* /saves* /rom* /conflicts* /devices* /events* /games* /catalog* /roadmap/items* /roadmap/suggestions* /parser* /referral* /dev* /stripe*
  }

  handle @api {
    reverse_proxy backend:3001
  }

  handle {
    reverse_proxy frontend:8080
  }
}
